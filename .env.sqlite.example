# ============================================================
# FastAPI Chassis — SQLite + In-Memory Rate Limiting
#
# Minimal preset: no extra infrastructure required.
# Works with a bare `uv sync` — no Postgres or Redis needed.
#
# Usage:
#   cp .env.sqlite.example .env
#   make install && make db-upgrade && make run
# ============================================================

# Application
APP_APP_NAME=FastAPI Chassis
APP_APP_VERSION=1.0.0
APP_APP_DESCRIPTION=Production-ready FastAPI template with secure-by-default configuration
APP_DEBUG=false
APP_DOCS_ENABLED=false
APP_REDOC_ENABLED=false
APP_OPENAPI_ENABLED=false

# Server (set APP_HOST=0.0.0.0 to expose on all interfaces)
APP_HOST=127.0.0.1
APP_PORT=8000

# Logging
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
# APP_LOG_TEXT_TEMPLATE=%(asctime)s | %(levelname)-8s | %(name)s | request_id=%(request_id)s | %(module)s:%(funcName)s:%(lineno)d | %(message)s
# APP_LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
# APP_LOGGING_CONFIG_PATH=  # Leave empty to use bundled default
APP_LOG_REDACT_HEADERS=false

# Database
APP_DATABASE_BACKEND=sqlite
APP_DATABASE_SQLITE_PATH=./data/app.db
# APP_DATABASE_BACKEND=postgres
# APP_DATABASE_BACKEND=custom

# Explicit URL overrides. Leave empty unless APP_DATABASE_BACKEND=custom
# or you want to bypass the derived defaults.
# APP_DATABASE_URL=
# APP_ALEMBIC_DATABASE_URL=

# Derived Postgres connection fields (unused in this preset).
# APP_DATABASE_POSTGRES_HOST=postgres
# APP_DATABASE_POSTGRES_PORT=5432
# APP_DATABASE_POSTGRES_NAME=fastapi_chassis
# APP_DATABASE_POSTGRES_USER=fastapi
# APP_DATABASE_POSTGRES_PASSWORD=change-me
APP_DATABASE_ECHO=false
APP_DATABASE_POOL_SIZE=5
APP_DATABASE_MAX_OVERFLOW=10
APP_DATABASE_POOL_PRE_PING=true
APP_DATABASE_CONNECT_TIMEOUT_SECONDS=5
APP_DATABASE_HEALTH_TIMEOUT_SECONDS=2

# SQLite production pragmas (applied automatically on every connection).
# These defaults are tuned for production use with WAL mode.
APP_DATABASE_SQLITE_JOURNAL_MODE=wal
APP_DATABASE_SQLITE_SYNCHRONOUS=normal
APP_DATABASE_SQLITE_BUSY_TIMEOUT=5000
APP_DATABASE_SQLITE_CACHE_SIZE=-64000
APP_DATABASE_SQLITE_MMAP_SIZE=0
APP_DATABASE_SQLITE_FOREIGN_KEYS=true

# Stateless JWT auth (resource server mode)
# Enable this only when you are ready to provide real verification material.
APP_AUTH_ENABLED=false
APP_AUTH_REQUIRE_EXP=true
APP_AUTH_REQUIRE_ISSUER=true
APP_AUTH_REQUIRE_AUDIENCE=true
# APP_AUTH_JWT_ISSUER=https://issuer.example.com/
# APP_AUTH_JWT_AUDIENCE=fastapi-chassis
APP_AUTH_JWT_ALGORITHMS=["HS256"]
# HS256 is intended for local/dev/test use only.
# APP_AUTH_JWT_SECRET=replace-with-a-32-character-minimum-secret
# APP_AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# APP_AUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
APP_AUTH_JWKS_CACHE_TTL_SECONDS=300
APP_AUTH_CLOCK_SKEW_SECONDS=30
APP_AUTH_HTTP_TIMEOUT_SECONDS=5

# CORS
# Set explicit origins in production; credentials require explicit origins, not "*".
APP_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
APP_CORS_ALLOW_CREDENTIALS=false
APP_CORS_ALLOWED_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
APP_CORS_ALLOWED_HEADERS=["Authorization","Content-Type","X-Request-ID","X-Correlation-ID"]
APP_CORS_EXPOSE_HEADERS=["X-Request-ID","X-Correlation-ID","X-RateLimit-Remaining"]

# Request handling and hardening
APP_REQUEST_TIMEOUT=30
APP_MAX_REQUEST_BODY_BYTES=5242880
APP_TRUSTED_HOSTS=["localhost","127.0.0.1"]
APP_SECURITY_HEADERS_ENABLED=true
APP_SECURITY_HSTS_ENABLED=false  # Usually enable only behind HTTPS
APP_SECURITY_HSTS_MAX_AGE_SECONDS=31536000
APP_SECURITY_REFERRER_POLICY=no-referrer
APP_SECURITY_PERMISSIONS_POLICY=geolocation=(), camera=(), microphone=()
APP_SECURITY_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'
APP_SECURITY_TRUST_PROXY_PROTO_HEADER=false
# Only enable forwarded-proto trust when the app is reachable exclusively
# through these proxy IPs/CIDRs.
APP_SECURITY_TRUSTED_PROXIES=["127.0.0.1/32"]

# Health checks
APP_HEALTH_CHECK_PATH=/healthcheck
APP_READINESS_CHECK_PATH=/ready
APP_READINESS_INCLUDE_DETAILS=false

# Diagnostic routes
APP_INFO_ENDPOINT_ENABLED=false
APP_ENDPOINTS_LISTING_ENABLED=false

# Metrics and tracing
APP_METRICS_ENABLED=false
APP_METRICS_PREFIX=http
APP_OTEL_ENABLED=false
APP_OTEL_SERVICE_NAME=fastapi-chassis
APP_OTEL_SERVICE_VERSION=1.0.0
APP_OTEL_ENVIRONMENT=development
APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# APP_OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer token

# Rate limiting (in-memory for this preset — no Redis needed)
APP_RATE_LIMIT_ENABLED=false
APP_RATE_LIMIT_REQUESTS=100
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_RATE_LIMIT_KEY_STRATEGY=ip
APP_RATE_LIMIT_STORAGE_BACKEND=memory
# APP_RATE_LIMIT_STORAGE_BACKEND=redis
# APP_RATE_LIMIT_STORAGE_URL=redis://localhost:6379/0  # Optional explicit override
APP_RATE_LIMIT_TRUST_PROXY_HEADERS=false
# Only enable forwarded-header trust when the app is reachable exclusively
# through these proxy IPs/CIDRs.
APP_RATE_LIMIT_TRUSTED_PROXIES=["127.0.0.1/32"]
APP_RATE_LIMIT_PROXY_HEADERS=["X-Forwarded-For","X-Real-IP"]

# Cache
APP_CACHE_ENABLED=false
APP_CACHE_BACKEND=memory
# APP_CACHE_BACKEND=redis
APP_CACHE_DEFAULT_TTL_SECONDS=300
APP_CACHE_MAX_ENTRIES=10000
APP_CACHE_KEY_PREFIX=cache:
APP_CACHE_REDIS_DB=1
# APP_CACHE_STORAGE_URL=redis://localhost:6379/1  # Optional explicit override
APP_CACHE_HEALTH_TIMEOUT_SECONDS=2

# Redis connection fields (unused in this preset).
# APP_REDIS_HOST=redis
# APP_REDIS_PORT=6379
# APP_REDIS_DB=0
# APP_REDIS_PASSWORD=change-me

